{
  "tailwindCSS.experimental.configFile": "app/globals.css",
  "files.associations": {
    "*.css": "tailwindcss"
  },
  "tailwindCSS.experimental.classRegex": [
    // JSX attribute syntax: containerClassName="..." selectClassName="..."
    ["[a-zA-Z]*[Cc]lassName\\s*=\\s*[\"']([^\"']*)[\"']", "([^\\s\"']+)"],
    // cn()/clsx() calls
    ["cn\\(([^)]*)\\)", "(?:'|\"|`)([^'\"`]*)(?:'|\"|`)"]
  ],
  "cSpell.words": [
    "currentcolor",
    "darkgradient",
    "darknone",
    "Devflow",
    "devicon",
    "Downvoted",
    "downvotes",
    "flagsapi",
    "googleusercontent",
    "grotesk",
    "jsearch",
    "mdxeditor",
    "mostanswered",
    "mostviewed",
    "mostvoted",
    "oklch",
    "RAPIDAPI",
    "restcountries",
    "Signinandout",
    "upserted",
    "upvotes",
    "vecteezy"
  ]
}
